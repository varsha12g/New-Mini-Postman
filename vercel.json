{
  "version": 2,
  "functions": {
    "frontend/server.js": {
      "includeFiles": "frontend/public/**"
    }
  },
  "builds": [
    {
      "src": "frontend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/server.js"
    }
  ]
}
